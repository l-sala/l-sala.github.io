{% assign repo_url = include.repository | split: '/' %}
{% assign owner = repo_url[0] %}
{% assign repo_name = repo_url[1] %}

{% comment %}Map repository name to the jekyll_get_json data key{% endcomment %}
{% assign repo_data = null %}
{% assign repo_name_lower = repo_name | downcase %}
{% if repo_name_lower == 'musclemotion' %}
  {% assign repo_data = site.data.github_repos_musclemotion %}
{% elsif repo_name_lower == 'bapta' %}
  {% assign repo_data = site.data.github_repos_bapta %}
{% elsif repo_name_lower == 'thorlabs_kiralux_concatenate_files' %}
  {% assign repo_data = site.data.github_repos_thorlabs %}
{% endif %}

<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.repository }}" class="text-decoration-none">
    <div class="card">
      <div class="card-body">
        <h5 class="card-title">
          <i class="fab fa-github"></i>
          {% if repo_data %}
            {{ repo_data.name }}
          {% else %}
            {{ repo_name }}
          {% endif %}
        </h5>
        <p class="card-text" style="color: var(--global-text-color-light); min-height: 3em;">
          {% if repo_data and repo_data.description %}
            {{ repo_data.description }}
          {% else %}
            No description available.
          {% endif %}
        </p>
        <div class="d-flex justify-content-center gap-3" style="font-size: 0.85rem; color: var(--global-text-color-light);">
          {% if repo_data.language %}
            <span>
              <i class="fas fa-circle" style="font-size: 0.6rem; vertical-align: middle;"></i>
              {{ repo_data.language }}
            </span>
          {% endif %}
          <span>
            <i class="far fa-star"></i>
            {% if repo_data %}{{ repo_data.stargazers_count }}{% else %}0{% endif %}
          </span>
          <span>
            <i class="fas fa-code-branch"></i>
            {% if repo_data %}{{ repo_data.forks_count }}{% else %}0{% endif %}
          </span>
        </div>
      </div>
    </div>
  </a>
</div>
